; properties configuration file (ini format)
;
; DO NOT DIRECTLY COPY OR EDIT THIS FILE. PLEASE ADD OR REMOVE CONFIGURATION FROM THE DEVICE'S REMOTE DESKTOP
;
; This file is the startup configuration file for the lamda server.
; You can use this file to configure the server's startup behavior, such as port, certificate, proxy,
; and other settings. You can configure it within the 65000 remote desktop.

[DEFAULT]
port=65000                      ; Set listening port for LAMDA.

; webui.* keys are only allowed in DEFAULT section
; You can preset various parameters of the remote desktop.
webui.darkmode = off            ; Whether to enable remote desktop darkmode theme.
webui.audio = on                ; Whether to enable remote desktop audio. (need android 10+)
webui.upload-path = /data/local/tmp/uploads ; Set the default directory for drag-and-drop upload in remote desktop.
webui.share-clipboard = off     ; Whether to enable remote desktop bidirectional clipboard sharing.
webui.touch.use-screen-size = off ; Use the original screen size to calculate touch coordinates (enable in special cases).
webui.webrtc = on               ; Whether to enable remote desktop WebRTC.
webui.webrtc.ice-server = stun:stun.device-farm.com ; Set the WebRTC STUN/TURN server addresses (separate multiple entries with commas).
                                                    ; example stun server: stun:stun.device-farm.com
                                                    ; example turn server: turn://user:pass@example.com:3478?transport=tcp
webui.video.h264 = on           ; Whether to enable H264 encoding (improves smoothness).
webui.video.backend = 0         ; Set the video backend implementation (0 = default or 1 = hardware).
webui.video.scale = 0.5         ; Set the video scaling ratio (0.1-1.0, where 1.0 represents full resolution).
webui.video.quality = 50        ; Set video quality (10-100).
webui.video.fps = 35            ; Set the expected video frame rate.

; Set service certificate. It will encrypt your remote desktop
; and API traffic, and enable password authentication. You can obtain
; the following configuration value by running 'base64 -w0 lamda.pem'.


; Set remote desktop login password, 6-32 characters.
; This password will only take effect if a service certificate
; is used. It serves as a backup password to the one generated in
; the certificate (for easier memorization).
ssl-web-credential=password123

; Set Access-Control-Allow-Origin header of firerpa webui
; and it's apis to allow you embed firerpa's features to your web application
; see https://developer.mozilla.org/en-US/docs/Web/HTTP/Headers/Access-Control-Allow-Origin
allow_origin=https://example.com

; ----- Remote Desktop Touch Fix -----
; If there is an offset or no response when you touch the screen on
; the remote desktop, please set the touch.backend configuration to system
; available options are: system | native (default)
touch.backend=system

; Set service log file (directory must exists)
logfile=/data/local/tmp/server.log

; ----- OpenVPN Configuration -----
; Do not manually write the following configuration. You should use
; our accompanying OpenVPN server setup solution to set it up and
; generate this configuration using its built-in commands.
[openvpn]
openvpn.proto=udp
openvpn.cipher=AES-256-GCM
openvpn.host=123.123.123.123
openvpn.port=1190
openvpn.ca=LS0tLS1CRU...
openvpn.cert=LS0tLS1CRU...
openvpn.key=LS0tLS1CRU...
openvpn.tls_encryption=
openvpn.tls_key_direction=
openvpn.tls_key=

; ONLY THE FOLLOWING CONFIGURATION ITEMS CAN BE MANUALLY CONFIGURED.
openvpn.global=false            ; Whether to enable global VPN.
openvpn.enable=true             ; Whether to enable the service true | false

; ----- Proxy Configuration -----
; This configuration is used to make the device automatically use a proxy server at startup.
[gproxy]
gproxy.enable=true              ; Whether to enable the service true | false
gproxy.type=http-connect        ; The proxy type can be either http-connect, https-connect, socks5, shadowsocks
gproxy.host=172.1.1.1           ; Proxy server address
gproxy.port=8080                ; Proxy server port
gproxy.password=                ; Proxy server login password (leave empty for no authentication)
gproxy.login=                   ; Proxy server login username (leave empty for no authentication, crypto method if type is shadowsocks)
gproxy.nameserver=              ; Custom DNS server
gproxy.drop_udp=false           ; Whether to discard UDP packets.
gproxy.udp_proxy=false          ; Whether to proxy UDP packets (requires proxy support, such as socks5, shadowsocks).
gproxy.bypass_local_subnet=true ; Do not proxy local area network traffic.
gproxy.dns_proxy=false          ; Make DNS queries go through the proxy (requires a DNS server that supports UDP and TCP).
gproxy.uid=                     ; Only proxy for specified UIDs. (default global)

# ----- CRONTAB Scheduled Task Service -----
# If you do not need scheduled tasks, you can disable this service.
[cron]
cron.enable=true                ; Whether to enable the service true | false

# ----- SSHD Service -----
# If you do not need to connect to the device via SSH, you can disable this service.
[sshd]
sshd.enable=true                ; Whether to enable the service true | false

# ----- Port Forwarding (frp) Service -----
[fwd]
fwd.enable=true                 ; Whether to enable the service true | false
fwd.rport=0                     ; Port to forward to the remote (0 means randomly allocated)
fwd.host=123.123.123.123        ; FRP server address
fwd.port=9911                   ; FRP server port
fwd.protocol=tcp                ; FRP protocol
fwd.token=abc123                ; FRP login authentication (token)

# ----- ADB Service -----
[adb]

adb.enable=true                 ; Whether to enable the service true | false
adb.directory=/data/local/tmp   ; Default working directory for built-in ADB (adb shell working directory)
; WARNING WARNING WARNING
; If set to true, the ADB connection will have root privileges,
; otherwise it will have shell privileges. When this option is set to false,
; you will be using a native-like adb shell, and you will not be able to use
; LAMDA's built-in commands. Please note that since ADB does not use TLS connections,
; traffic may be monitored. For security reasons, when the LAMDA service is
; started with a certificate, this value will be set to false by default.
; However, if you specify it in the properties.local file, the configuration
; in the file will take precedence.
; You are responsible for ensuring security.
adb.privileged=true

# ----- Bridge Proxy Service -----
[tunnel2]
tunnel2.enable=true             ; Whether to enable the service true | false
; The bridge proxy will require login authentication only if both login and password
; are set. If either one is left empty, no login authentication will be required.
tunnel2.login=lamda
tunnel2.password=1234           ; Login password for the bridge proxy
; Outbound interface (rmnet|wlan)
; When the outbound interface is rmnet, the proxy will attempt to forward your requests through mobile data.
; When the outbound interface is wlan, requests will be forwarded through the wlan interface.
; If the configuration is empty, the default network will be used to forward the requests.
tunnel2.iface=rmnet
; You can test the proxy by using curl -x http://192.168.x.x:65000 https://httpbin.org/ip
; (no username or password configured by default). If you have enabled certificate,
; you need to use curl -x https://lamda:cert-password@192.168.x.x:65000 https://httpbin.org/ip--proxy-insecure -v
; (or reconfigure the login name and password).

# ----- mDNS Broadcast Service -----
[mdns]
mdns.enable=false               ; Enable or disable true | false
mdns.meta=false                 ; Add TXT metadata for mDNS. When enabled, it will support querying device information such as model, ABI, and device ID using tools like python-zeroconf. Disabled by default.
mdns.name=DEVICEID-UNIQUE.lamda ; Set the broadcast domain name using a locally unique ID, default is {DEVICEID-UNIQUE}.lamda. If the name duplicates in the local network, a suffix ID will be automatically added.
mdns.service=lamda              ; Set the broadcast service name, default is lamda, i.e., _lamda._tcp.local.