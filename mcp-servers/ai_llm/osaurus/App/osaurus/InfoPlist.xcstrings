    "NSAppleEventsUsageDescription" : {
      "comment" : "Privacy - AppleEvents Sending Usage Description",
      "extractionState" : "extracted_with_value",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Osaurus-Plugins können Automatisierung nutzen, um andere Anwendungen in deinem Auftrag zu steuern."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Osaurus uses automation to control other applications on your behalf — including agents that write and run AppleScript to automate tasks on this Mac, and plugins that use automation."
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Osaurus 플러그인이 사용자를 대신하여 다른 응용 프로그램을 제어하기 위해 자동화를 사용할 수 있습니다."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Osaurus использует автоматизацию, чтобы управлять другими приложениями от вашего имени: в том числе агенты могут писать и запускать AppleScript для автоматизации задач на этом Mac, а плагины могут использовать автоматизацию."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Osaurus 插件可能会使用自动化代表你控制其他应用。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Osaurus 插件可能會用自動化來代表你控制其他應用。"
          }
        }
      }
    },
    "NSCalendarsFullAccessUsageDescription" : {
      "comment" : "Privacy - Calendars Full Access Usage Description",
      "extractionState" : "extracted_with_value",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Osaurus-Plugins können auf deinen Kalender zugreifen, um Termine zu lesen und zu erstellen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Osaurus plugins may access your calendar to read and create events."
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Osaurus 플러그인이 이벤트를 읽고 생성하기 위해 캘린더에 접근할 수 있습니다."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Плагины Osaurus могут получать доступ к календарю, чтобы читать и создавать события."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Osaurus 插件可能会访问你的日历，以读取和创建日程。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Osaurus 插件可能會讀取你的行事曆，用來讀取和建立行事曆。"
          }
        }
      }
    },
    "NSCalendarsUsageDescription" : {
      "comment" : "Privacy - Calendars Usage Description",
