    "NSContactsUsageDescription" : {
      "comment" : "Privacy - Contacts Usage Description",
      "extractionState" : "extracted_with_value",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Osaurus-Plugins können auf deine Kontakte zugreifen, um Kontaktinformationen zu suchen und zu lesen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Osaurus plugins may access your contacts to search and read contact information."
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Osaurus 플러그인이 연락처 정보를 검색하고 읽기 위해 연락처에 접근할 수 있습니다."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Плагины Osaurus могут получать доступ к контактам, чтобы искать и читать контактную информацию."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Osaurus 插件可能会访问你的联系人，以搜索和读取联系人信息。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Osaurus 插件可能會存取你的聯絡人，以搜尋和讀取聯絡人資訊。"
          }
        }
      }
    },
    "NSHumanReadableCopyright" : {
      "comment" : "Copyright (human-readable)",
      "extractionState" : "extracted_with_value",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "new",
