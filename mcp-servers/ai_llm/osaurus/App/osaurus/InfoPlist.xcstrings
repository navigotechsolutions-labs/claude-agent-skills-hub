    "NSMicrophoneUsageDescription" : {
      "comment" : "Privacy - Microphone Usage Description",
      "extractionState" : "extracted_with_value",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Osaurus verwendet das Mikrofon für die Spracherkennung auf dem Gerät mit FluidAudio."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Osaurus uses the microphone for on-device voice transcription with FluidAudio."
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Osaurus가 FluidAudio를 사용한 온디바이스 음성 텍스트 변환을 위해 마이크를 사용합니다."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Osaurus использует микрофон для локальной расшифровки речи с помощью FluidAudio."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Osaurus 使用麦克风通过 FluidAudio 进行设备端语音转写。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Osaurus 使用麥克風透過 FluidAudio 進行裝置端語音轉寫。"
          }
        }
      }
    },
    "NSRemindersUsageDescription" : {
      "comment" : "Privacy - Reminders Usage Description",
      "extractionState" : "extracted_with_value",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Osaurus-Plugins können auf deine Erinnerungen zugreifen, um Aufgaben zu lesen und zu erstellen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Osaurus plugins may access your reminders to read and create tasks."
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Osaurus 플러그인이 작업을 읽고 생성하기 위해 미리 알림에 접근할 수 있습니다."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Плагины Osaurus могут получать доступ к напоминаниям, чтобы читать и создавать задачи."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Osaurus 插件可能会访问你的提醒事项，以读取和创建任务。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Osaurus 插件可能會存取你的提醒事項，以讀取和建立任務。"
          }
        }
      }
    },
    "NSScreenCaptureUsageDescription" : {
      "comment" : "Privacy - Screen Capture Usage Description",
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Osaurus kann Screenshots und Systemaudio nur erfassen, wenn du den Zugriff auf Bildschirmaufnahme erlaubst."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Osaurus can capture screenshots and system audio only when you grant Screen Recording access."
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Osaurus는 화면 기록 접근 권한을 부여한 경우에만 스크린샷 및 시스템 오디오를 캡처할 수 있습니다."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Osaurus может записывать снимки экрана и системный звук только после предоставления доступа к записи экрана."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "只有在你授予屏幕录制访问权限时，Osaurus 才能捕获屏幕截图和系统音频。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "只有在你授予螢幕錄製存取權限時，Osaurus 才能擷取螢幕截圖和系統音訊。"
          }
        }
      }
    }
  },
  "version" : "1.0"
